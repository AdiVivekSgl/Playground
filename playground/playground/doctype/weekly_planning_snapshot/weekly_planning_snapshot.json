{
 "doctype": "DocType",
 "name": "Weekly Planning Snapshot",
 "module": "Playground",
 "custom": 0,
 "istable": 0,
 "issingle": 0,
 "is_submittable": 1,
 "naming_rule": "Expression (old style)",
 "autoname": "WPS-.#####",
 "track_changes": 1,
 "engine": "InnoDB",
 "sort_field": "modified",
 "sort_order": "DESC",
 "fields": [
  {
   "fieldname": "snapshot_date",
   "fieldtype": "Date",
   "label": "Snapshot Date",
   "reqd": 1,
   "in_list_view": 1,
   "description": "Not unique at the DocType level - validate() only blocks a second SUBMITTED snapshot on the same date, so a cancelled snapshot can be re-approved on that date."
  },
  {
   "fieldname": "col_break_1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "generated_by",
   "fieldtype": "Link",
   "options": "User",
   "label": "Generated By",
   "read_only": 1,
   "default": "__user"
  },
  {
   "fieldname": "approved_by",
   "fieldtype": "Link",
   "options": "User",
   "label": "Approved By",
   "read_only": 1,
   "description": "Set automatically on submit - approve_snapshot() inserts and submits in one action, so generating and approving are the same step, done by the same person."
  },
  {
   "fieldname": "approved_on",
   "fieldtype": "Datetime",
   "label": "Approved On",
   "read_only": 1
  },
  {
   "fieldname": "remarks_section",
   "fieldtype": "Section Break",
   "label": "Remarks"
  },
  {
   "fieldname": "remarks",
   "fieldtype": "Small Text",
   "label": "Remarks"
  },
  {
   "fieldname": "items_section",
   "fieldtype": "Section Break",
   "label": "Snapshot Items"
  },
  {
   "fieldname": "items",
   "fieldtype": "Table",
   "options": "Weekly Planning Snapshot Item",
   "label": "Items",
   "reqd": 1,
   "description": "Frozen at approval time. If a snapshot was approved in error, cancel it (standard Frappe cancel+amend) and re-run the Weekly Planning Snapshot Review report instead of editing these rows."
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "submit": 1,
   "cancel": 1,
   "amend": 1
  },
  {
   "role": "Manufacturing Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "submit": 1,
   "cancel": 1,
   "amend": 1
  },
  {
   "role": "Manufacturing User",
   "read": 1
  },
  {
   "role": "Sales Manager",
   "read": 1
  }
 ]
}
